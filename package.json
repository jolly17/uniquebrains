{
  "name": "uniquebrains-marketplace",
  "version": "1.0.0",
  "description": "UniqueBrains - Where every brain learns differently",
  "homepage": "https://jolly17.github.io/uniquebrains",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap && node scripts/update-meta-tags.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "prebuild": "npm run generate-sitemap",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d docs",
    "verify-supabase": "node scripts/verify-supabase-setup.js",
    "verify-auth": "node scripts/verify-auth-config.js",
    "verify-oauth": "node scripts/verify-oauth-setup.js",
    "check-db": "node scripts/check-database-tables.js"
  },
  "reactSnap": {
    "source": "docs",
    "minifyHtml": {
      "collapseWhitespace": true,
      "removeComments": true
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/courses",
      "/content",
      "/content/neurodiversity",
      "/content/sensory-differences",
      "/community",
      "/care",
      "/privacy-policy",
      "/terms-of-service"
    ],
    "skipThirdPartyRequests": true,
    "cacheAjaxRequests": false,
    "preconnectThirdParty": false
  },
  "dependencies": {
    "@sentry/react": "^10.38.0",
    "@sentry/vite-plugin": "^4.9.0",
    "@supabase/supabase-js": "^2.95.3",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "dotenv": "^17.2.4",
    "fast-check": "^4.5.3",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.1.0",
    "react-snap": "^1.23.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
